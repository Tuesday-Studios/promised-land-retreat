---
/**
 * Large-format image display with optional text overlay.
 * Designed to give professional photography the space it deserves.
 */
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  alt: string;
  caption?: string;
  aspectRatio?: 'cinematic' | 'landscape' | 'wide' | 'natural';
  parallax?: boolean;
}

const {
  image,
  alt,
  caption,
  aspectRatio = 'cinematic',
  parallax = false,
} = Astro.props;
---

<figure class:list={[
  'showcase',
  `showcase--${aspectRatio}`,
  { 'showcase--parallax': parallax },
  'fade-in'
]}>
  <div class="showcase__frame">
    <Image
      src={image}
      alt={alt}
      widths={[800, 1200, 1600, 2000]}
      sizes="100vw"
      class="showcase__image"
      quality={85}
    />
  </div>
  {caption && (
    <figcaption class="showcase__caption container">
      {caption}
    </figcaption>
  )}
</figure>

<style>
  .showcase {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin: var(--space-lg) 0;
  }

  .showcase__frame {
    width: 100%;
    overflow: hidden;
  }

  .showcase--cinematic .showcase__frame {
    aspect-ratio: 21 / 9;
  }

  .showcase--landscape .showcase__frame {
    aspect-ratio: 16 / 9;
  }

  .showcase--wide .showcase__frame {
    aspect-ratio: 3 / 1;
  }

  .showcase--natural .showcase__frame {
    aspect-ratio: auto;
  }

  .showcase__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .showcase:hover .showcase__image {
    transform: scale(1.03);
  }

  .showcase--parallax .showcase__image {
    height: 120%;
    object-position: center 20%;
  }

  .showcase__caption {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--text-light);
    padding-top: var(--space-sm);
    padding-bottom: 0;
  }

  @media (max-width: 767px) {
    .showcase--cinematic .showcase__frame {
      aspect-ratio: 16 / 9;
    }

    .showcase--wide .showcase__frame {
      aspect-ratio: 16 / 9;
    }
  }
</style>
