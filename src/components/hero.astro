---
/**
 * Full-viewport hero with immersive photography.
 * The image IS the hero. Everything else is secondary.
 */
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  imageAlt: string;
  title?: string;
  subtitle?: string;
  cta?: { label: string; href: string };
  overlay?: 'dark' | 'gradient' | 'subtle';
  height?: 'full' | 'tall' | 'medium';
}

const {
  image,
  imageAlt,
  title,
  subtitle,
  cta,
  overlay = 'gradient',
  height = 'full',
} = Astro.props;
---

<section class:list={['hero', `hero--${height}`, `hero--overlay-${overlay}`]}>
  <div class="hero__image-wrap">
    <Image
      src={image}
      alt={imageAlt}
      widths={[800, 1200, 1600, 2000]}
      sizes="100vw"
      class="hero__image"
      loading="eager"
      quality={85}
    />
  </div>

  {(title || subtitle || cta) && (
    <div class="hero__content">
      <div class="hero__text">
        {title && <h1 class="hero__title">{title}</h1>}
        {subtitle && <p class="hero__subtitle">{subtitle}</p>}
        {cta && (
          <a href={cta.href} class="btn btn-light hero__cta">
            {cta.label}
          </a>
        )}
      </div>
    </div>
  )}

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .hero--full {
    height: 100vh;
    min-height: 600px;
  }

  .hero--tall {
    height: 85vh;
    min-height: 500px;
  }

  .hero--medium {
    height: 65vh;
    min-height: 400px;
  }

  /* Image */
  .hero__image-wrap {
    position: absolute;
    inset: 0;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Overlays — never opaque. Let the photo live. */
  .hero--overlay-dark::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(42, 31, 20, 0.2) 0%,
      rgba(42, 31, 20, 0.1) 40%,
      rgba(42, 31, 20, 0.5) 100%
    );
  }

  .hero--overlay-gradient::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(26, 46, 26, 0.15) 0%,
      transparent 30%,
      transparent 50%,
      rgba(42, 31, 20, 0.45) 85%,
      rgba(42, 31, 20, 0.65) 100%
    );
  }

  .hero--overlay-subtle::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 60%,
      rgba(42, 31, 20, 0.3) 100%
    );
  }

  /* Content */
  .hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    z-index: 2;
    padding: var(--space-2xl) var(--space-md);
  }

  @media (min-width: 768px) {
    .hero__content {
      padding: var(--space-3xl) var(--space-xl);
    }
  }

  .hero__text {
    max-width: 700px;
  }

  .hero__title {
    color: var(--mist);
    font-weight: 300;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.25);
    margin-bottom: 0.5rem;
    animation: heroFadeUp 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  .hero__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: rgba(247, 244, 239, 0.8);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.2);
    max-width: 540px;
    margin-bottom: var(--space-lg);
    animation: heroFadeUp 1.2s 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  .hero__cta {
    animation: heroFadeUp 1.2s 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: heroFadeUp 1.2s 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(
      180deg,
      transparent,
      rgba(247, 244, 239, 0.6)
    );
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scrollPulse {
    0%, 100% {
      opacity: 0.4;
      transform: scaleY(1);
    }
    50% {
      opacity: 1;
      transform: scaleY(1.2);
    }
  }

  .hero--full .hero__scroll { display: block; }
  .hero--tall .hero__scroll,
  .hero--medium .hero__scroll { display: none; }
</style>
