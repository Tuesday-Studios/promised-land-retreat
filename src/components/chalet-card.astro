---
/**
 * Large-format chalet preview card.
 * NOT a tiny thumbnail card. Big image, clear info, inviting.
 */
import { Image } from 'astro:assets';

interface Props {
  name: string;
  tagline: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  bedrooms: string;
  guests: string;
  href: string;
  reverse?: boolean;
}

const {
  name,
  tagline,
  description,
  image,
  imageAlt,
  bedrooms,
  guests,
  href,
  reverse = false,
} = Astro.props;
---

<article class:list={['chalet-card', { 'chalet-card--reverse': reverse }, 'fade-in']}>
  <a href={href} class="chalet-card__image-link">
    <div class="chalet-card__image-wrap">
      <Image
        src={image}
        alt={imageAlt}
        widths={[600, 900, 1200]}
        sizes="(min-width: 768px) 55vw, 100vw"
        class="chalet-card__image"
        quality={85}
      />
    </div>
  </a>

  <div class="chalet-card__content">
    <span class="chalet-card__tagline">{tagline}</span>
    <h3 class="chalet-card__name">
      <a href={href}>{name}</a>
    </h3>
    <hr class="divider" />
    <p class="chalet-card__desc">{description}</p>

    <div class="chalet-card__details">
      <span class="chalet-card__detail">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 7v11a2 2 0 002 2h14a2 2 0 002-2V7" />
          <path d="M21 10H3" />
          <path d="M7 10V7a2 2 0 012-2h6a2 2 0 012 2v3" />
        </svg>
        {bedrooms}
      </span>
      <span class="chalet-card__detail">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="7" r="4" />
          <path d="M5.5 21a6.5 6.5 0 0113 0" />
        </svg>
        {guests}
      </span>
    </div>

    <a href={href} class="btn btn-secondary chalet-card__btn">
      View Chalet
    </a>
  </div>
</article>

<style>
  .chalet-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (min-width: 768px) {
    .chalet-card {
      grid-template-columns: 1.3fr 1fr;
      gap: var(--space-2xl);
    }

    .chalet-card--reverse {
      grid-template-columns: 1fr 1.3fr;
    }

    .chalet-card--reverse .chalet-card__image-link {
      order: 2;
    }

    .chalet-card--reverse .chalet-card__content {
      order: 1;
    }
  }

  .chalet-card__image-link {
    display: block;
    text-decoration: none;
  }

  .chalet-card__image-wrap {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .chalet-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease-out);
  }

  .chalet-card__image-link:hover .chalet-card__image {
    transform: scale(1.04);
  }

  .chalet-card__content {
    padding: var(--space-sm) 0;
  }

  @media (min-width: 768px) {
    .chalet-card__content {
      padding: var(--space-lg) 0;
    }
  }

  .chalet-card__tagline {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
  }

  .chalet-card__name {
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .chalet-card__name a {
    color: var(--text-dark);
    text-decoration: none;
    transition: color 0.3s;
  }

  .chalet-card__name a:hover {
    color: var(--timber);
  }

  .chalet-card__desc {
    color: var(--text-mid);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .chalet-card__details {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .chalet-card__detail {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-light);
  }

  .chalet-card__detail svg {
    color: var(--timber-light);
  }

  .chalet-card__btn {
    font-size: 0.75rem;
    padding: 0.75rem 2rem;
  }
</style>
