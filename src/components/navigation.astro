---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/chalets/', label: 'Chalets' },
  { href: '/property/', label: 'The Property' },
  { href: '/location/', label: 'Location' },
  { href: '/contact/', label: 'Contact' },
];
---

<nav class:list={['nav', { 'nav--transparent': transparent }]} id="main-nav">
  <div class="nav__inner container">
    <a href="/" class="nav__logo" aria-label="Promised Land Retreat — Home">
      <span class="nav__logo-text">Promised Land</span>
      <span class="nav__logo-sub">Retreat</span>
    </a>

    <button
      class="nav__toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      id="nav-toggle"
    >
      <span class="nav__toggle-line"></span>
      <span class="nav__toggle-line"></span>
    </button>

    <div class="nav__menu" id="nav-menu">
      <ul class="nav__links">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav__link', { 'nav__link--active': currentPath === link.href }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <a
        href="https://apac.littlehotelier.com/properties/promisedlanddirect"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary nav__book"
      >
        Book Your Stay
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 0;
    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .nav--scrolled {
    background: rgba(247, 244, 239, 0.95);
    backdrop-filter: blur(12px);
    padding: 0.75rem 0;
    box-shadow: 0 1px 0 rgba(92, 58, 30, 0.08);
  }

  .nav--transparent {
    background: transparent;
  }

  .nav--transparent:not(.nav--scrolled) .nav__logo-text,
  .nav--transparent:not(.nav--scrolled) .nav__logo-sub {
    color: var(--mist);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.3);
  }

  .nav--transparent:not(.nav--scrolled) .nav__link {
    color: rgba(247, 244, 239, 0.85);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  .nav--transparent:not(.nav--scrolled) .nav__link:hover,
  .nav--transparent:not(.nav--scrolled) .nav__link--active {
    color: var(--mist);
  }

  .nav--transparent:not(.nav--scrolled) .nav__toggle-line {
    background: var(--mist);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-decoration: none;
  }

  .nav__logo-text {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--timber-deep);
    transition: color 0.5s;
  }

  .nav__logo-sub {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    color: var(--timber-mid);
    text-transform: uppercase;
    transition: color 0.5s;
  }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav__links {
    display: flex;
    list-style: none;
    gap: 0.25rem;
  }

  .nav__link {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-mid);
    padding: 0.5rem 1rem;
    transition: color 0.3s;
    text-decoration: none;
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--timber-deep);
  }

  .nav__link--active {
    font-weight: 500;
  }

  .nav__book {
    font-size: 0.75rem;
    padding: 0.75rem 1.75rem;
  }

  /* Hamburger */
  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 110;
  }

  .nav__toggle-line {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--timber-deep);
    transition: all 0.35s var(--ease-out);
    transform-origin: center;
  }

  .nav__toggle[aria-expanded="true"] .nav__toggle-line:first-child {
    transform: rotate(45deg) translate(2.5px, 2.5px);
  }

  .nav__toggle[aria-expanded="true"] .nav__toggle-line:last-child {
    transform: rotate(-45deg) translate(2.5px, -2.5px);
  }

  /* Mobile */
  @media (max-width: 900px) {
    .nav__toggle {
      display: flex;
    }

    .nav__menu {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(380px, 85vw);
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      gap: 2rem;
      padding: 3rem;
      background: var(--mist);
      transform: translateX(100%);
      transition: transform 0.5s var(--ease-out);
      box-shadow: -20px 0 60px rgba(0, 0, 0, 0.1);
    }

    .nav__menu.open {
      transform: translateX(0);
    }

    .nav__links {
      flex-direction: column;
      gap: 0;
    }

    .nav__link {
      font-size: 1rem;
      padding: 0.75rem 0;
      letter-spacing: 0.05em;
    }

    .nav__book {
      margin-top: 1rem;
    }
  }
</style>

<script>
  // Scroll handling
  const nav = document.getElementById('main-nav');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const scroll = window.scrollY;
    if (scroll > 80) {
      nav?.classList.add('nav--scrolled');
    } else {
      nav?.classList.remove('nav--scrolled');
    }
    lastScroll = scroll;
  });

  // Mobile menu toggle
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('open');
  });
</script>
