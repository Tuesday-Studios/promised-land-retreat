---
/**
 * Chalet detail layout component. Large hero, gallery, amenities, booking CTA.
 * Designed to make someone immediately want to stay here.
 */
import { Image } from 'astro:assets';
import ImageGallery from './image-gallery.astro';

interface GalleryImage {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  name: string;
  tagline: string;
  description: string;
  heroImage: ImageMetadata;
  heroAlt: string;
  galleryImages: GalleryImage[];
  floorplan?: ImageMetadata;
  bedrooms: string;
  bathrooms: string;
  guests: string;
  position: string;
  features: string[];
}

const {
  name,
  tagline,
  description,
  heroImage,
  heroAlt,
  galleryImages,
  floorplan,
  bedrooms,
  bathrooms,
  guests,
  position,
  features,
} = Astro.props;
---

<!-- Hero Image — massive, full width -->
<section class="chalet-hero">
  <div class="chalet-hero__image-wrap">
    <Image
      src={heroImage}
      alt={heroAlt}
      widths={[800, 1200, 1600, 2000]}
      sizes="100vw"
      class="chalet-hero__image"
      loading="eager"
      quality={85}
    />
  </div>
  <div class="chalet-hero__overlay"></div>
  <div class="chalet-hero__content container">
    <span class="chalet-hero__tagline">{tagline}</span>
    <h1 class="chalet-hero__title">{name}</h1>
  </div>
</section>

<!-- Detail Content -->
<section class="chalet-detail">
  <div class="container">
    <div class="chalet-detail__grid">
      <!-- Main description -->
      <div class="chalet-detail__main fade-in">
        <p class="lead">{description}</p>
        <hr class="divider" />
        <p class="chalet-detail__position">{position}</p>
      </div>

      <!-- Quick facts sidebar -->
      <aside class="chalet-detail__sidebar fade-in delay-2">
        <div class="chalet-detail__facts">
          <div class="chalet-detail__fact">
            <span class="chalet-detail__fact-label">Bedrooms</span>
            <span class="chalet-detail__fact-value">{bedrooms}</span>
          </div>
          <div class="chalet-detail__fact">
            <span class="chalet-detail__fact-label">Bathrooms</span>
            <span class="chalet-detail__fact-value">{bathrooms}</span>
          </div>
          <div class="chalet-detail__fact">
            <span class="chalet-detail__fact-label">Guests</span>
            <span class="chalet-detail__fact-value">{guests}</span>
          </div>
        </div>
        <a
          href="https://apac.littlehotelier.com/properties/promisedlanddirect"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary chalet-detail__book"
        >
          Book This Chalet
        </a>
        <p class="chalet-detail__call">
          Or call <a href="tel:0494107195">0494 107 195</a>
        </p>
      </aside>
    </div>
  </div>
</section>

<!-- Gallery -->
<section class="chalet-gallery">
  <div class="container">
    <ImageGallery images={galleryImages} />
  </div>
</section>

<!-- Features -->
<section class="chalet-features">
  <div class="container">
    <h3 class="chalet-features__title fade-in">What's Included</h3>
    <ul class="chalet-features__list fade-in delay-1">
      {features.map((feature) => (
        <li class="chalet-features__item">{feature}</li>
      ))}
    </ul>
  </div>
</section>

<!-- Floorplan -->
{floorplan && (
  <section class="chalet-floorplan">
    <div class="container">
      <h3 class="chalet-floorplan__title fade-in">Floor Plan</h3>
      <div class="chalet-floorplan__image-wrap fade-in delay-1">
        <Image
          src={floorplan}
          alt={`${name} floor plan`}
          width={800}
          class="chalet-floorplan__image"
          quality={90}
        />
      </div>
    </div>
  </section>
)}

<!-- Booking CTA -->
<section class="chalet-cta">
  <div class="container">
    <div class="chalet-cta__content fade-in">
      <h2>Stay at {name}</h2>
      <p>Book direct for the best rates. No platform fees.</p>
      <div class="chalet-cta__actions">
        <a
          href="https://apac.littlehotelier.com/properties/promisedlanddirect"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          Check Availability
        </a>
        <a href="/chalets/" class="btn btn-secondary">
          View All Chalets
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hero */
  .chalet-hero {
    position: relative;
    height: 70vh;
    min-height: 450px;
    overflow: hidden;
  }

  .chalet-hero__image-wrap {
    position: absolute;
    inset: 0;
  }

  .chalet-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .chalet-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(42, 31, 20, 0.1) 0%,
      transparent 30%,
      transparent 50%,
      rgba(42, 31, 20, 0.55) 100%
    );
  }

  .chalet-hero__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding-bottom: var(--space-xl);
  }

  .chalet-hero__tagline {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber-light);
    display: block;
    margin-bottom: 0.5rem;
    animation: heroFadeUp 1s 0.1s var(--ease-out) both;
  }

  .chalet-hero__title {
    color: var(--mist);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.2);
    animation: heroFadeUp 1s 0.2s var(--ease-out) both;
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Detail grid */
  .chalet-detail {
    padding: var(--space-2xl) 0;
  }

  .chalet-detail__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .chalet-detail__grid {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .chalet-detail__main .lead {
    max-width: none;
  }

  .chalet-detail__position {
    color: var(--text-mid);
    font-style: italic;
  }

  /* Sidebar */
  .chalet-detail__sidebar {
    position: sticky;
    top: 100px;
    align-self: start;
  }

  .chalet-detail__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--mist-warm);
    margin-bottom: var(--space-md);
  }

  .chalet-detail__fact {
    text-align: center;
  }

  .chalet-detail__fact-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 0.3rem;
  }

  .chalet-detail__fact-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--text-dark);
  }

  .chalet-detail__book {
    width: 100%;
    text-align: center;
  }

  .chalet-detail__call {
    text-align: center;
    margin-top: var(--space-sm);
    font-size: 0.85rem;
    color: var(--text-light);
  }

  .chalet-detail__call a {
    color: var(--timber);
    font-weight: 500;
  }

  /* Gallery */
  .chalet-gallery {
    padding: 0 0 var(--space-2xl);
  }

  /* Features */
  .chalet-features {
    padding: var(--space-2xl) 0;
    background: var(--mist-warm);
  }

  .chalet-features__title {
    margin-bottom: var(--space-lg);
  }

  .chalet-features__list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    max-width: 800px;
  }

  @media (min-width: 640px) {
    .chalet-features__list {
      grid-template-columns: 1fr 1fr;
    }
  }

  .chalet-features__item {
    font-size: 0.95rem;
    color: var(--text-mid);
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.5;
  }

  .chalet-features__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border: 1.5px solid var(--amber);
    border-radius: 50%;
  }

  /* Floorplan */
  .chalet-floorplan {
    padding: var(--space-2xl) 0;
  }

  .chalet-floorplan__title {
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .chalet-floorplan__image-wrap {
    max-width: 700px;
    margin: 0 auto;
  }

  .chalet-floorplan__image {
    width: 100%;
    height: auto;
  }

  /* CTA */
  .chalet-cta {
    padding: var(--space-2xl) 0;
    background: var(--timber-deep);
    text-align: center;
  }

  .chalet-cta__content {
    max-width: 480px;
    margin: 0 auto;
  }

  .chalet-cta h2 {
    color: var(--mist);
    margin-bottom: var(--space-sm);
  }

  .chalet-cta p {
    color: rgba(247, 244, 239, 0.65);
    margin: 0 auto var(--space-lg);
  }

  .chalet-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .chalet-cta .btn-primary {
    background: var(--amber);
    color: var(--timber-deep);
  }

  .chalet-cta .btn-primary:hover {
    background: var(--amber-light);
  }

  .chalet-cta .btn-secondary {
    color: var(--mist);
    border-color: rgba(247, 244, 239, 0.3);
  }

  .chalet-cta .btn-secondary:hover {
    background: var(--mist);
    color: var(--timber-deep);
  }
</style>
