---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Image } from 'astro:assets'

import heroImage from '@/assets/promised_9722.jpg'
import interior from '@/assets/promised_9345a.jpg'
import kitchen from '@/assets/promised_9403.jpg'
import bedroom from '@/assets/promised_9466.jpg'
import bathroom from '@/assets/promised_9408-2.jpg'
import viewInside from '@/assets/promised_9735.jpg'
import interior2 from '@/assets/promised_9818.jpg'
import viewKitchen from '@/assets/promised_extra_9492-2.jpg'
import floorplan from '@/assets/Tallowood.jpg'
import ctaImage from '@/assets/PLR_9769.jpg'
---

<BaseLayout
  title="Tallowood — Family Chalet | Promised Land Retreat"
  description="Tallowood is a two-bedroom timber chalet with accessible bathroom, spa bath, and mountain views. Named after the towering tallowood trees that surround it. Book direct."
  transparentHeader
>

  <section class="hero" aria-label="Tallowood">
    <Image src={heroImage} alt="Tallowood chalet — timber exterior with round window, the Dorrigo escarpment visible through trees" class="hero__bg" widths={[800, 1200, 1600, 2000]} sizes="100vw" loading="eager" />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__content">
      <span class="hero__tag">Family Chalet</span>
      <h1>Tallowood</h1>
      <p class="lead">Two bedrooms. Warm timber interiors. An accessible bathroom with spa bath. Named after the towering tallowood trees that frame the view to the mountains.</p>
      <a href="https://apac.littlehotelier.com/properties/promisedlanddirect" class="btn btn--amber" target="_blank" rel="noopener">Book Tallowood</a>
    </div>
  </section>

  <section class="detail section--parchment" aria-label="About Tallowood">
    <div class="detail__grid">
      <div class="detail__text">
        <h2>Timber, light, and mountains</h2>
        <p>Tallowood sits alongside The Ridge at the western end of the property, separated by mature plantings so each chalet has its own world. The name comes from the towering tallowood trees — a coastal eucalypt — that frame the approach.</p>
        <p>Inside, it's all warmth. Timber walls, natural light pouring through floor-to-ceiling glass, and mountain views that shift colour through the day. The bathroom is fully accessible, with both a spa bath and a separate shower — the only chalet with this configuration.</p>
        <p>Two bedrooms (one with a queen, one with a queen and two singles) make it flexible for families or groups. The kitchen is fully equipped, the living area is generous, and the deck with its electric BBQ catches the afternoon sun with the escarpment as its permanent backdrop.</p>
      </div>
      <div class="detail__images">
        <div class="img-frame detail__img-tall">
          <Image src={interior} alt="Tallowood interior — pink sofa, mountain views through floor-to-ceiling glass walls" widths={[600, 900]} sizes="(max-width: 768px) 90vw, 45vw" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="gallery section--linen" aria-label="Tallowood gallery">
    <div class="gallery__inner">
      <h2>Gallery</h2>
      <div class="gallery__grid">
        <div class="gallery__item gallery__item--wide img-frame">
          <Image src={viewKitchen} alt="View from Tallowood kitchen — mountains framed through the glass" widths={[600, 900, 1200]} sizes="(max-width: 768px) 90vw, 60vw" loading="lazy" />
        </div>
        <div class="gallery__item img-frame">
          <Image src={kitchen} alt="Tallowood kitchen — well-equipped with timber surrounds" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 30vw" loading="lazy" />
        </div>
        <div class="gallery__item img-frame">
          <Image src={bedroom} alt="Tallowood bedroom — queen bed, timber walls, mountain light" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 30vw" loading="lazy" />
        </div>
        <div class="gallery__item img-frame">
          <Image src={bathroom} alt="Tallowood accessible bathroom — spa bath and separate shower" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 30vw" loading="lazy" />
        </div>
        <div class="gallery__item img-frame">
          <Image src={viewInside} alt="View from inside Tallowood — mountains through the glass" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 30vw" loading="lazy" />
        </div>
        <div class="gallery__item gallery__item--wide img-frame">
          <Image src={interior2} alt="Tallowood interior — warm timber, natural light, comfortable living" widths={[600, 900]} sizes="(max-width: 768px) 90vw, 60vw" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="floorplan section--parchment" aria-label="Floor plan">
    <div class="floorplan__inner">
      <h2>Floor Plan</h2>
      <div class="floorplan__image">
        <Image src={floorplan} alt="Tallowood floor plan — two bedrooms, accessible bathroom, open living area, deck" widths={[600, 900]} sizes="(max-width: 768px) 90vw, 60vw" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="specs section--linen" aria-label="Tallowood specifications">
    <div class="specs__inner">
      <div class="specs__grid">
        <div class="spec-group">
          <h3>Sleeping</h3>
          <ul><li>Bedroom 1: queen bed</li><li>Bedroom 2: queen + 2 singles</li></ul>
        </div>
        <div class="spec-group">
          <h3>Bathroom</h3>
          <ul><li>Accessible layout</li><li>Spa bath</li><li>Separate shower</li></ul>
        </div>
        <div class="spec-group">
          <h3>Kitchen</h3>
          <ul><li>Ceramic cooktop</li><li>Full oven</li><li>Microwave</li><li>210L fridge</li></ul>
        </div>
        <div class="spec-group">
          <h3>Living</h3>
          <ul><li>Large living area</li><li>Reverse-cycle A/C</li><li>Ceiling fan</li><li>Sliding glass doors</li></ul>
        </div>
        <div class="spec-group">
          <h3>Outdoors</h3>
          <ul><li>Sun-drenched deck</li><li>Electric BBQ</li><li>Mountain views</li></ul>
        </div>
        <div class="spec-group">
          <h3>Character</h3>
          <ul><li>Surrounded by tallowood trees</li><li>Accessible bathroom</li><li>Warm pink and timber tones</li></ul>
        </div>
      </div>
    </div>
  </section>

  <section class="cta" aria-label="Book Tallowood">
    <Image src={ctaImage} alt="A chalet glowing warmly at night on the hillside" class="cta__bg" widths={[800, 1200, 1600]} sizes="100vw" loading="lazy" />
    <div class="cta__overlay" aria-hidden="true"></div>
    <div class="cta__content">
      <h2>Book Tallowood</h2>
      <p>Direct booking — no middleman, no extra fees. Or call Sophie to ask about anything at all.</p>
      <div class="cta__actions">
        <a href="https://apac.littlehotelier.com/properties/promisedlanddirect" class="btn btn--amber" target="_blank" rel="noopener">Check Availability</a>
        <a href="tel:0494107195" class="btn btn--ghost-light">Call 0494 107 195</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero — page-specific overrides */
  .hero { min-height: 70vh; }
  .hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hero__content { position: relative; z-index: 2; max-width: 72rem; margin: 0 auto; padding: 0 1.5rem 4rem; width: 100%; color: var(--color-mist); }
  .hero__tag { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-amber); display: block; margin-bottom: 0.75rem; }
  .hero h1 { margin-bottom: 1rem; }
  .hero .lead { margin-bottom: 2rem; }

  .detail { padding: clamp(4rem,8vw,7rem) 1.5rem; }
  .detail__grid { max-width: 72rem; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start; }
  @media (min-width: 900px) { .detail__grid { grid-template-columns: 3fr 2fr; gap: 5rem; } }
  .detail__text h2 { margin-bottom: 1.25rem; }
  .detail__text p { color: var(--color-escarpment); margin-bottom: 1rem; }
  .detail__img-tall { aspect-ratio: 3/4; }
  .detail__img-tall img { width: 100%; height: 100%; object-fit: cover; }

  .gallery { padding: clamp(4rem,8vw,7rem) 1.5rem; }
  .gallery__inner { max-width: 72rem; margin: 0 auto; }
  .gallery__inner h2 { margin-bottom: 2rem; }
  .gallery__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .gallery__item { aspect-ratio: 4/3; }
  .gallery__item--wide { grid-column: span 2; aspect-ratio: 21/9; }
  @media (max-width: 600px) { .gallery__grid { grid-template-columns: 1fr; } .gallery__item--wide { grid-column: span 1; aspect-ratio: 16/9; } }

  .floorplan { padding: clamp(3rem,6vw,5rem) 1.5rem; }
  .floorplan__inner { max-width: 48rem; margin: 0 auto; text-align: center; }
  .floorplan__inner h2 { margin-bottom: 2rem; }
  .floorplan__image img { width: 100%; height: auto; }

  .specs { padding: clamp(3rem,6vw,5rem) 1.5rem; }
  .specs__inner { max-width: 72rem; margin: 0 auto; }
  .specs__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 2rem; }
  .spec-group h3 { font-size: 1.15rem; margin-bottom: 0.75rem; color: var(--color-timber); }
  .spec-group ul { list-style: none; padding: 0; }
  .spec-group li { font-size: 0.9rem; color: var(--color-escarpment); padding: 0.3rem 0; border-bottom: 1px solid rgba(0,0,0,0.06); }

  /* CTA — page-specific min-height override */
  .cta { min-height: 50vh; }
</style>
