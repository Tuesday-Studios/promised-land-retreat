---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Image } from 'astro:assets'

import sophieImage from '@/assets/sophie.jpg'
import heroImage from '@/assets/promised_9369_01.jpg'
---

<BaseLayout
  title="Contact & Booking — Promised Land Retreat"
  description="Get in touch with Sophie at Promised Land Retreat. Book direct for the best rates. Phone 0494 107 195, email sophie@promisedlandretreat.com.au. Gift vouchers available."
  transparentHeader
>

  <section class="hero" aria-label="Contact us">
    <Image src={heroImage} alt="View through glass doors to the chalet deck and mountain panorama beyond" class="hero__bg" widths={[800, 1200, 1600, 2000]} sizes="100vw" loading="eager" />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__content">
      <h1>Get in Touch</h1>
      <p class="lead">We'd love to have you come and stay with us. Give us a call if you have any questions — or book direct for the best rates.</p>
    </div>
  </section>

  <!-- Contact details + Sophie -->
  <section class="contact-info section--parchment" aria-label="Contact information">
    <div class="contact-info__inner">
      <div class="contact-info__main">
        <div class="contact-methods">
          <div class="contact-method">
            <h3>Book Direct</h3>
            <p>No middleman, no extra fees. Our booking system shows live availability and lets you reserve instantly.</p>
            <a href="https://apac.littlehotelier.com/properties/promisedlanddirect" class="btn btn--amber" target="_blank" rel="noopener">Check Availability &amp; Book</a>
          </div>
          <div class="contact-method">
            <h3>Phone</h3>
            <p>The best way to ask questions or chat about what to do in the area.</p>
            <a href="tel:0494107195" class="contact-link">0494 107 195</a>
          </div>
          <div class="contact-method">
            <h3>Email</h3>
            <p>Happy to answer any questions by email — Sophie usually replies within a day.</p>
            <a href="mailto:sophie@promisedlandretreat.com.au" class="contact-link">sophie@promisedlandretreat.com.au</a>
          </div>
          <div class="contact-method">
            <h3>Gift Vouchers</h3>
            <p>Looking for a gift that people actually want? A stay at Promised Land makes a pretty good one. Call or email to arrange a voucher for any amount or duration.</p>
          </div>
        </div>
      </div>
      <div class="contact-info__sophie">
        <div class="sophie-card">
          <div class="sophie-card__image img-frame">
            <Image src={sophieImage} alt="Sophie Warburton — owner of Promised Land Retreat" widths={[400, 600]} sizes="(max-width: 768px) 50vw, 25vw" loading="lazy" />
          </div>
          <div class="sophie-card__text">
            <h3>Sophie</h3>
            <p>Sophie Warburton runs Promised Land Retreat with warmth, good food, and zero pretension. She cooks French provincial with an Aussie accent, keeps the grounds beautifully manicured, and has never taken a selfie in her life. She'd rather chat on the phone than on social media — so give her a ring.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Getting here / directions -->
  <section class="directions section--linen" aria-label="Directions">
    <div class="directions__inner">
      <h2>Finding us</h2>
      <div class="directions__grid">
        <div class="directions__text">
          <h3>The Address</h3>
          <p class="address">934 Promised Land Road<br/>Gleniffer, NSW 2454<br/>Australia</p>
          <h3>From Sydney (5.5 hours)</h3>
          <p>Pacific Highway north to the Raleigh / Urunga exit. Through Bellingen village, then follow Promised Land Road. We're at number 934 — you'll see the platanus trees lining the driveway.</p>
          <h3>From Brisbane (5 hours)</h3>
          <p>Pacific Highway south. Same exit at Raleigh / Urunga. We're roughly halfway between Sydney and Brisbane.</p>
          <h3>By Air</h3>
          <p>Fly into Coffs Harbour Airport (45 minutes from the property). Regular flights from Sydney, Melbourne, and Brisbane. You'll want a hire car for exploring the area.</p>
        </div>
        <div class="directions__map">
          <div class="map-wrapper">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3499.1!2d152.775!3d-30.425!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzDCsDI1JzMwLjAiUyAxNTLCsDQ2JzMwLjAiRQ!5e0!3m2!1sen!2sau!4v1"
              title="Map showing location of Promised Land Retreat, Gleniffer NSW"
              loading="lazy"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social & press -->
  <section class="social section--dark" aria-label="Find us online">
    <div class="social__inner">
      <h2>Find us elsewhere</h2>
      <div class="social__grid">
        <a href="https://www.facebook.com/pages/Promised-Land-Retreat/130155923704489" class="social__link" target="_blank" rel="noopener">Facebook</a>
        <a href="https://www.instagram.com/explore/tags/promisedlandretreat/" class="social__link" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.tripadvisor.com.au/Hotel_Review-g488319-d293687-Reviews-Promised_Land_Cottages" class="social__link" target="_blank" rel="noopener">TripAdvisor</a>
      </div>
      <div class="press-mentions">
        <h3>As featured in</h3>
        <ul>
          <li>Lonely Planet Australia, 19th Edition (2018) — selected purely on merit</li>
          <li>traveller.com.au — "Six of the best boutique stays between Sydney and Brisbane"</li>
          <li>notquitenigella.com — Bellingen food and things to do</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Final quote -->
  <section class="final-quote section--parchment" aria-label="A word from Sophie">
    <div class="final-quote__inner">
      <blockquote>
        <p>"We'd love to have you come and stay with us. Give us a call if you have any questions."</p>
        <footer><cite>Sophie</cite></footer>
      </blockquote>
      <a href="tel:0494107195" class="btn btn--outline">Call 0494 107 195</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero — page-specific overrides (different min-height, overlay gradient, content layout) */
  .hero { min-height: 55vh; }
  .hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 20%, rgba(26,30,36,0.4) 60%, rgba(26,30,36,0.75) 100%); }
  .hero__content { position: relative; z-index: 2; max-width: 72rem; margin: 0 auto; padding: 0 1.5rem 4rem; width: 100%; color: var(--color-mist); }
  .hero h1 { margin-bottom: 1rem; }

  /* Contact info */
  .contact-info { padding: clamp(4rem,8vw,7rem) 1.5rem; }
  .contact-info__inner { max-width: 72rem; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 900px) { .contact-info__inner { grid-template-columns: 3fr 2fr; gap: 5rem; } }

  .contact-methods { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  @media (max-width: 600px) { .contact-methods { grid-template-columns: 1fr; } }
  .contact-method { padding: 1.5rem; background: var(--color-linen); border-radius: 0.5rem; }
  .contact-method h3 { font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--color-timber); }
  .contact-method p { font-size: 0.9rem; color: var(--color-escarpment); margin-bottom: 1rem; max-width: none; }
  .contact-link { color: var(--color-timber); font-weight: 500; text-decoration: none; font-size: 0.95rem; border-bottom: 1px solid var(--color-bark); padding-bottom: 2px; }
  .contact-link:hover { color: var(--color-amber); border-color: var(--color-amber); }

  /* Sophie card */
  .sophie-card { background: var(--color-linen); border-radius: 0.5rem; overflow: hidden; }
  .sophie-card__image { aspect-ratio: 4/3; }
  .sophie-card__image img { width: 100%; height: 100%; object-fit: cover; }
  .sophie-card__text { padding: 1.5rem; }
  .sophie-card__text h3 { font-size: 1.25rem; margin-bottom: 0.75rem; }
  .sophie-card__text p { font-size: 0.9rem; color: var(--color-escarpment); max-width: none; }

  /* Directions */
  .directions { padding: clamp(4rem,8vw,7rem) 1.5rem; }
  .directions__inner { max-width: 72rem; margin: 0 auto; }
  .directions__inner h2 { margin-bottom: 2.5rem; }
  .directions__grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 900px) { .directions__grid { grid-template-columns: 1fr 1fr; gap: 4rem; } }
  .directions__text h3 { font-size: 1.1rem; margin: 1.5rem 0 0.5rem; color: var(--color-timber); }
  .directions__text h3:first-child { margin-top: 0; }
  .directions__text p { font-size: 0.9rem; color: var(--color-escarpment); max-width: none; }
  .address { font-size: 1.05rem; color: var(--color-timber); line-height: 1.6; margin-bottom: 1rem; }
  .map-wrapper { position: relative; padding-bottom: 75%; height: 0; border-radius: 0.5rem; overflow: hidden; }
  .map-wrapper iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }

  /* Social */
  .social { padding: clamp(4rem,8vw,6rem) 1.5rem; }
  .social__inner { max-width: 56rem; margin: 0 auto; text-align: center; }
  .social__inner h2 { color: var(--color-mist); margin-bottom: 2rem; }
  .social__grid { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 3rem; }
  .social__link { padding: 0.75rem 1.75rem; border: 1px solid rgba(247,244,239,0.3); border-radius: 0.375rem; color: var(--color-mist); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: background 0.3s, border-color 0.3s; }
  .social__link:hover { background: rgba(247,244,239,0.1); border-color: rgba(247,244,239,0.5); }

  .press-mentions { border-top: 1px solid rgba(247,244,239,0.15); padding-top: 2rem; }
  .press-mentions h3 { font-size: 1rem; color: var(--color-amber); margin-bottom: 1rem; }
  .press-mentions ul { list-style: none; padding: 0; }
  .press-mentions li { font-size: 0.9rem; color: rgba(247,244,239,0.65); padding: 0.4rem 0; }

  /* Final quote */
  .final-quote { padding: clamp(4rem,8vw,6rem) 1.5rem; text-align: center; }
  .final-quote__inner { max-width: 42rem; margin: 0 auto; }
  .final-quote blockquote p { font-family: var(--font-display); font-style: italic; font-size: clamp(1.5rem, 3vw, 2.25rem); line-height: 1.4; color: var(--color-timber); margin-bottom: 1.5rem; max-width: none; }
  .final-quote cite { font-family: var(--font-body); font-style: normal; font-weight: 500; color: var(--color-amber); font-size: 0.9rem; }
  .final-quote .btn { margin-top: 2rem; }
</style>
