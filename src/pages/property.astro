---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Image } from 'astro:assets'

import heroImage from '@/assets/Ken_Spence-12.jpg'
import donkeys from '@/assets/P1030337.jpg'
import tennis from '@/assets/Ken_Spence-57.jpg'
import tennisDay from '@/assets/Tennis.jpg'
import bikes from '@/assets/P1000304.jpg'
import gamesroom from '@/assets/gamesroom.jpg'
import eggs from '@/assets/eggs.jpg'
import chooks from '@/assets/chooks.jpg'
import garden from '@/assets/P1040323.jpg'
import bees from '@/assets/P1040114.jpg'
import birding from '@/assets/promised_9806.jpg'
import showcaseImage from '@/assets/promised_9661-2.jpg'
import ctaImage from '@/assets/Ken_Spence-34.jpg'
---

<BaseLayout
  title="The Property — 100 Acres | Promised Land Retreat"
  description="100 acres of farmland beneath the Dorrigo escarpment. Tennis court, mountain bikes, swimming holes, fresh eggs, friendly donkeys, games room, birdwatching. Explore the property."
  transparentHeader
>

  <section class="hero" aria-label="The Property">
    <Image src={heroImage} alt="Sweeping view of the 100-acre property — green pastures, timber chalets, and the Dorrigo escarpment behind" class="hero__bg" widths={[800, 1200, 1600, 2000]} sizes="100vw" loading="eager" />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__content">
      <h1>A hundred acres</h1>
      <p class="lead">Tennis under floodlights. Mountain bikes on back roads. Swimming in crystal-clear river water. Fresh eggs, donkeys, birdsong. A hundred acres of farmland beneath the Dorrigo escarpment — and it's all yours.</p>
    </div>
  </section>

  <!-- Donkeys — hero feature -->
  <section class="feature-section section--parchment" aria-label="Friendly donkeys">
    <div class="feature-split">
      <div class="feature-split__image img-frame">
        <Image src={donkeys} alt="Friendly donkeys in the green paddock, curious and approaching the camera" widths={[600, 900, 1200]} sizes="(max-width: 768px) 90vw, 50vw" loading="lazy" />
      </div>
      <div class="feature-split__text">
        <h2>The donkeys</h2>
        <p>They're the unofficial welcoming committee. Our small herd of donkeys lives in the paddock beside the chalets, and they'll wander over to say hello — especially if you have an apple. Guests come back just to see them.</p>
      </div>
    </div>
  </section>

  <!-- Tennis -->
  <section class="feature-section section--linen" aria-label="Tennis court">
    <div class="feature-split feature-split--reverse">
      <div class="feature-split__image img-frame">
        <Image src={tennis} alt="Full-size tennis court lit up for night games under floodlights, mountains silhouetted behind" widths={[600, 900, 1200]} sizes="(max-width: 768px) 90vw, 50vw" loading="lazy" />
      </div>
      <div class="feature-split__text">
        <h2>Night tennis</h2>
        <p>A full-size artificial grass tennis court with floodlights for night games. Racquets and balls provided. There's something about playing tennis at night with the mountains as backdrop and no one around for miles. Challenge your partner to a set under the stars.</p>
      </div>
    </div>
  </section>

  <!-- Cinematic break -->
  <div class="showcase" aria-label="Property landscape">
    <Image src={showcaseImage} alt="Two chalets on the green hillside with the Dorrigo Range rising behind" widths={[800, 1200, 1600, 2000]} sizes="100vw" loading="lazy" />
  </div>

  <!-- Never Never Creek -->
  <section class="feature-section section--dark" aria-label="Never Never Creek">
    <div class="feature-text-center">
      <h2>Never Never Creek</h2>
      <p class="lead">Crystal-clear swimming holes just a short walk from the property. Granite boulders worn smooth by centuries of water, dappled light through the canopy, water cold enough to shock you awake on a summer morning. The Promised Land Loop Road passes more swimming holes — easy to reach by bike or car.</p>
      <p>The river runs through some of the most pristine country on the mid-north coast. Bring a towel and leave your phone behind.</p>
    </div>
  </section>

  <!-- Grid of smaller features -->
  <section class="facilities section--parchment" aria-label="Property facilities">
    <div class="facilities__inner">
      <h2>Everything on the property</h2>
      <div class="facilities__grid">
        <div class="facility-card">
          <div class="facility-card__image img-frame">
            <Image src={bikes} alt="Quality mountain bikes ready for guests to ride the local roads" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 25vw" loading="lazy" />
          </div>
          <h3>Mountain bikes</h3>
          <p>Quality bikes for guests. Ride the Promised Land Loop Road through swimming holes and mountain vistas. Cycle to the Gleniffer swimming hole — an easy ride from the property.</p>
        </div>
        <div class="facility-card">
          <div class="facility-card__image img-frame">
            <Image src={gamesroom} alt="Games room with pool table, ping-pong table, books and board games" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 25vw" loading="lazy" />
          </div>
          <h3>Games room</h3>
          <p>Pool table, ping-pong, books, DVDs, board games. For rainy afternoons or evenings when you want to stay in but not stay still.</p>
        </div>
        <div class="facility-card">
          <div class="facility-card__image img-frame">
            <Image src={eggs} alt="A bowl of fresh free-range eggs collected from the property" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 25vw" loading="lazy" />
          </div>
          <h3>Fresh eggs</h3>
          <p>Help yourself from the chicken coop each morning. Our chooks produce more than we can eat — the least we can do is share.</p>
        </div>
        <div class="facility-card">
          <div class="facility-card__image img-frame">
            <Image src={garden} alt="Veggie garden and fruit orchard on the property" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 25vw" loading="lazy" />
          </div>
          <h3>Garden & orchard</h3>
          <p>Veggie garden and fruit orchard — guests welcome to pick whatever's ripe. Citrus trees heavy with fruit, seasonal herbs, whatever the garden offers that week.</p>
        </div>
        <div class="facility-card">
          <div class="facility-card__image img-frame">
            <Image src={birding} alt="Binoculars and bird field guide on a deck table, a guest birdwatching in the background" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 25vw" loading="lazy" />
          </div>
          <h3>Birdwatching</h3>
          <p>Binoculars and a field guide in every chalet. The property is home to Whip Birds, Kookaburras, Honeyeaters, Cockatoos, and dozens more species. You don't need to go looking — they come to you.</p>
        </div>
        <div class="facility-card">
          <div class="facility-card__image img-frame">
            <Image src={bees} alt="Honey bees on the property — active hive" widths={[400, 600]} sizes="(max-width: 768px) 45vw, 25vw" loading="lazy" />
          </div>
          <h3>Honey bees</h3>
          <p>We keep bees on the property. The honey is as local as it gets.</p>
        </div>
      </div>
      <div class="facilities__extras">
        <h3>Also on the property</h3>
        <ul>
          <li>Laundry — washing, drying, and ironing facilities</li>
          <li>Gift vouchers available for stays and experiences</li>
          <li>No city lights — genuine stargazing from your deck</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Video -->
  <section class="video-section section--linen" aria-label="Property video">
    <div class="video-section__inner">
      <h2>See for yourself</h2>
      <div class="video-wrapper">
        <iframe
          src="https://www.youtube.com/embed/4swFiwo20rs"
          title="Promised Land Retreat — aerial tour of the property and surrounding landscape"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" aria-label="Book your stay">
    <Image src={ctaImage} alt="Couple on a chalet deck beneath a canopy of stars" class="cta__bg" widths={[800, 1200, 1600]} sizes="100vw" loading="lazy" />
    <div class="cta__overlay" aria-hidden="true"></div>
    <div class="cta__content">
      <h2>A hundred acres, all yours</h2>
      <p>Book direct for the best rate. No middleman, no booking fees.</p>
      <div class="cta__actions">
        <a href="https://apac.littlehotelier.com/properties/promisedlanddirect" class="btn btn--amber" target="_blank" rel="noopener">Check Availability</a>
        <a href="/contact" class="btn btn--ghost-light">Get in Touch</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero — page-specific overrides (different overlay gradient and content layout from global) */
  .hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 20%, rgba(26,30,36,0.4) 60%, rgba(26,30,36,0.75) 100%); }
  .hero__content { position: relative; z-index: 2; max-width: 72rem; margin: 0 auto; padding: 0 1.5rem 4rem; width: 100%; color: var(--color-mist); }
  .hero h1 { margin-bottom: 1rem; }
  .hero .lead { max-width: 56ch; }

  .feature-section { padding: clamp(4rem,8vw,7rem) 1.5rem; }
  .feature-split { max-width: 72rem; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center; }
  @media (min-width: 900px) { .feature-split { grid-template-columns: 1fr 1fr; gap: 5rem; } .feature-split--reverse .feature-split__image { order: 1; } }
  .feature-split__text h2 { margin-bottom: 1rem; }
  .feature-split__text p { color: var(--color-escarpment); line-height: 1.7; }
  .section--dark .feature-split__text p { color: rgba(247,244,239,0.75); }

  .feature-text-center { max-width: 56rem; margin: 0 auto; text-align: center; }
  .feature-text-center h2 { color: var(--color-mist); margin-bottom: 1.5rem; }
  .feature-text-center .lead { color: rgba(247,244,239,0.85); margin: 0 auto 1.5rem; text-align: center; }
  .feature-text-center p { color: rgba(247,244,239,0.65); margin: 0 auto; text-align: center; }

  .showcase { aspect-ratio: 21/9; overflow: hidden; width: 100%; }
  .showcase img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 8s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
  .showcase:hover img { transform: scale(1.03); }
  @media (max-width: 768px) { .showcase { aspect-ratio: 16/9; } }
  @media (prefers-reduced-motion: reduce) { .showcase img { transition: none; } .showcase:hover img { transform: none; } }

  .facilities { padding: clamp(4rem,8vw,7rem) 1.5rem; }
  .facilities__inner { max-width: 72rem; margin: 0 auto; }
  .facilities__inner > h2 { margin-bottom: 3rem; }
  .facilities__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-bottom: 3rem; }
  .facility-card { background: var(--color-linen); border-radius: 0.5rem; overflow: hidden; }
  .facility-card__image { aspect-ratio: 16/10; }
  .facility-card h3 { padding: 1.25rem 1.25rem 0.25rem; font-size: 1.2rem; }
  .facility-card p { padding: 0 1.25rem 1.25rem; font-size: 0.9rem; color: var(--color-escarpment); max-width: none; }

  .facilities__extras { border-top: 1px solid rgba(0,0,0,0.1); padding-top: 2rem; }
  .facilities__extras h3 { margin-bottom: 1rem; font-size: 1.15rem; }
  .facilities__extras ul { list-style: none; padding: 0; }
  .facilities__extras li { padding: 0.5rem 0; font-size: 0.95rem; color: var(--color-escarpment); border-bottom: 1px solid rgba(0,0,0,0.06); }

  .video-section { padding: clamp(4rem,8vw,7rem) 1.5rem; }
  .video-section__inner { max-width: 56rem; margin: 0 auto; }
  .video-section__inner h2 { margin-bottom: 2rem; text-align: center; }
  .video-wrapper { position: relative; padding-bottom: 56.25%; height: 0; border-radius: 0.5rem; overflow: hidden; }
  .video-wrapper iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }

  /* CTA — page-specific min-height override */
  .cta { min-height: 50vh; }
</style>
